# Copy to .env.do and fill in values. NEVER commit .env.do
#
# cp .env.do.example .env.do
# chmod 600 .env.do

# Required
DIGITALOCEAN_ACCESS_TOKEN=your-digitalocean-api-token
SSH_PUBLIC_KEY_PATH=~/.ssh/id_rsa.pub
SSH_PRIVATE_KEY_PATH=~/.ssh/id_rsa

# Your public IP for firewall (curl -s ifconfig.me)/32
SSH_ALLOWED_CIDR=0.0.0.0/0

# Terraform sizing (V1 minimal)
TF_REGION=nyc3
TF_WORKER_COUNT=1
TF_DROPLET_SIZE=s-1vcpu-1gb
TF_POSTGRES_SIZE=db-s-1vcpu-1gb
RABBITMQ_USERNAME=asyncjobs
RABBITMQ_PASSWORD=change-me-strong-password

# Docker image (built by GitHub Actions on push to main)
DOCKER_IMAGE=ghcr.io/yashthecoder123456/async-job-processing-service:latest

# Set true to skip confirmation prompts
AUTO_APPROVE=false

# Set false to skip production smoke test after deploy
RUN_SMOKE_TEST=true
