# Database
DATABASE_URL=jdbc:postgresql://postgres:5432/asyncjobs
DATABASE_USERNAME=asyncjobs
DATABASE_PASSWORD=asyncjobs

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_MANAGEMENT_URL=http://guest:guest@rabbitmq:15672

# Application roles (api | worker | dispatcher | all)
APP_ROLE=all
API_ENABLED=true
WORKER_ENABLED=true
OUTBOX_DISPATCHER_ENABLED=true

# Worker
WORKER_CONCURRENCY=4
WORKER_POLL_INTERVAL_MS=100
WORKER_ID_PREFIX=worker
WORKER_LEASE_SECONDS=60
DB_POOL_MAX_SIZE=15
DB_POOL_MIN_IDLE=2

# Retry backoff
BACKOFF_BASE_MS=1000
BACKOFF_MAX_MS=60000
BACKOFF_JITTER_MS=500

# Outbox
OUTBOX_BATCH_SIZE=50
OUTBOX_POLL_INTERVAL_MS=500

# Ops
DRAIN_SUBMISSIONS_WHEN_ENABLED=true
MAX_PAYLOAD_BYTES=65536

# Spring
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080
